# AquaClaw (雪蟹) Environment Configuration

# Assistant Settings
ASSISTANT_NAME="雪蟹"
ASSISTANT_HAS_OWN_NUMBER="false"

# LLM Provider: OpenRouter (Default)
# OpenRouter provides an Anthropic-compatible API.
# You can use any model available on OpenRouter (e.g., Claude 3.5 Sonnet).
ANTHROPIC_BASE_URL="https://openrouter.ai/api/v1"
ANTHROPIC_AUTH_TOKEN="your-openrouter-api-key"
ANTHROPIC_MODEL="anthropic/claude-3.5-sonnet"
OPENROUTER_API_KEY="your-openrouter-api-key"

# To use Anthropic directly, comment out OpenRouter settings and use these:
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# ANTHROPIC_BASE_URL="https://api.anthropic.com"

# To use Google Gemini, set these:
# GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# Discord Bot Token (Required for Discord command adapter)
AC_DISCORD_TOKEN="your-discord-bot-token"

# Performance & Concurrency
MAX_CONCURRENT_CONTAINERS="5"
CONTAINER_TIMEOUT="1800000"
IDLE_TIMEOUT="1800000"

# Log Level: debug, info, warn, error
LOG_LEVEL="info"
