# AquaClaw (雪蟹) Environment Configuration

# Assistant Settings
ASSISTANT_NAME="雪蟹"
ASSISTANT_HAS_OWN_NUMBER="false"

# LLM Configuration
# Set your model here (provider-agnostic name)
# Default: anthropic/claude-3.5-sonnet
AC_MODEL="anthropic/claude-3.5-sonnet"

# LLM Provider: OpenRouter (Default)
# Just set your key here. AquaClaw automatically handles the base URL and model defaults.
OPENROUTER_API_KEY="your-openrouter-api-key"

# To use Anthropic directly, set this and comment out OpenRouter settings:
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# To use Google Gemini, set this:
# GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# Discord Bot Token (Required for Discord command adapter)
AC_DISCORD_TOKEN="your-discord-bot-token"

# Proxy Settings (Optional, useful for regions like China)
# HTTPS_PROXY="http://127.0.0.1:7890"
# HTTP_PROXY="http://127.0.0.1:7890"

# Performance & Concurrency
MAX_CONCURRENT_CONTAINERS="5"
CONTAINER_TIMEOUT="1800000"
IDLE_TIMEOUT="1800000"

# Log Level: debug, info, warn, error
LOG_LEVEL="info"
